# ValUprop.in — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.

# ─── Database ────────────────────────────────────────────────────
# Local dev (SQLite — no setup needed):
DATABASE_URL=sqlite:///./valuprop_dev.db

# Production (PostgreSQL on AWS RDS ap-south-1):
# DATABASE_URL=postgresql://valuprop_user:yourpassword@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/valuprop

# ─── OpenAI ──────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# Optionally swap to Claude (Anthropic):
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Razorpay ────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_ keys for development, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_HERE
RAZORPAY_KEY_SECRET=YOUR_SECRET_HERE

# Report price in paise (100 paise = ₹1)
# ₹99 = 9900 paise
REPORT_PRICE_PAISE=9900

# ─── Email (Resend) ──────────────────────────────────────────────
# Get from: https://resend.com (free: 3,000 emails/month)
# Verify your domain at resend.com/domains first
RESEND_API_KEY=re_YOUR_KEY_HERE
FROM_EMAIL=reports@valuprop.in
FROM_NAME=ValUprop.in

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local dev:
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
# Production: ALLOWED_ORIGINS=https://valuprop.in,https://www.valuprop.in

# ─── App settings ────────────────────────────────────────────────
# Set to true to skip LLM calls and use static data (useful for UI testing)
DEV_MODE=false

# ─── AWS S3 (PDF storage) ─────────────────────────────────────────
# Create IAM user with S3 PutObject/GetObject permissions
# Create bucket: valuprop-reports in ap-south-1
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
S3_BUCKET=valuprop-reports
PDF_URL_EXPIRY_SECS=604800   # 7 days = 7 * 24 * 3600

# ─── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MIN=10        # Max API calls per IP per minute
