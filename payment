<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Unlock Detailed Report — valUProp.in</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css"/>
  <style>
    .pay-wrap { max-width: 480px; margin: 30px auto; padding: 0 20px; }
    .pay-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; margin-bottom: 16px; box-shadow: var(--shadow-sm); }
    .pay-header { font-family: var(--font-head); font-size: 22px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
    .pay-sub { font-size: 14px; color: var(--muted); margin-bottom: 18px; }
    .summary-label { font-size: 11px; font-weight: 700; letter-spacing: 0.5px; color: var(--muted); text-transform: uppercase; margin-bottom: 12px; }
    .summary-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
    .summary-row:last-child { border-bottom: none; padding-top: 14px; font-weight: 700; font-size: 16px; }
    .summary-row .row-label { color: var(--muted); }
    .summary-row .row-val { color: var(--text); text-align: right; max-width: 60%; }
    .email-confirm { background: #ECFDF5; border: 1px solid #A7F3D0; border-radius: var(--radius-sm); padding: 12px 14px; font-size: 13px; color: #065F46; margin-bottom: 16px; }
    .security-note { background: var(--bg); border-radius: var(--radius-sm); padding: 12px 14px; font-size: 12px; color: var(--muted); margin-bottom: 18px; display: flex; align-items: center; gap: 10px; }
    .pay-btn { width: 100%; background: var(--accent); color: white; border: none; padding: 16px; font-size: 16px; font-weight: 700; font-family: var(--font-head); border-radius: var(--radius-sm); cursor: pointer; transition: all 0.15s; }
    .pay-btn:hover { background: var(--accent-dark); transform: translateY(-1px); }
    .pay-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="nav-inner">
      <div class="logo">valUProp<span class="logo-dot">.in</span></div>
      <a href="results.html" class="btn-back-nav">← Back to estimate</a>
    </div>
  </nav>

  <main class="pay-wrap">
    <div class="pay-card">
      <div class="pay-header">Unlock Detailed Report</div>
      <div class="pay-sub">One-time payment · PDF emailed instantly · 7-day refund guarantee</div>

      <div class="summary-label">ORDER SUMMARY</div>
      <div class="summary-row">
        <span class="row-label">Property</span>
        <span class="row-val" id="pay-prop">Loading...</span>
      </div>
      <div class="summary-row">
        <span class="row-label">Report type</span>
        <span class="row-val">Detailed Valuation Report (7 sections)</span>
      </div>
      <div class="summary-row">
        <span class="row-label">Delivery</span>
        <span class="row-val">PDF emailed to your email</span>
      </div>
      <div class="summary-row">
        <span class="row-label">Valid for</span>
        <span class="row-val">48 hours from generation</span>
      </div>
      <div class="summary-row">
        <span class="row-label">Total</span>
        <span class="row-val">₹99</span>
      </div>
    </div>

    <div class="email-confirm">
      ✓ Your report will be emailed as a PDF to <strong id="pay-email-confirm">your email address</strong>.
      You can also download it directly from the next page.
    </div>

    <div class="security-note">
      <span style="font-size:20px;flex-shrink:0;">🔒</span>
      <div>
        <strong>Secured by Razorpay</strong> · 256-bit SSL encryption · PCI-DSS compliant<br/>
        <span style="font-size:12px;">UPI / GPay / PhonePe / Credit Card / Debit Card / Net Banking / Paytm</span>
      </div>
    </div>

    <button class="pay-btn" id="pay-btn" onclick="initiatePayment()">
      Pay ₹99 &amp; Get My Report →
    </button>

    <p style="font-size:12px;color:var(--muted-light);text-align:center;margin-top:12px;">
      7-day no-questions-asked refund · <a href="pages/refund.html">Refund Policy</a>
    </p>
  </main>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="js/estimate.js"></script>
  <script>
    // ─── RAZORPAY SETUP ────────────────────────────────────────────
    // Replace the placeholder below with your actual rzp_test_ key from razorpay.com
    const RAZORPAY_KEY_ID = 'rzp_test_SkKhIC1M8yKbMX';
    const BACKEND_URL = window.BACKEND_URL || 'https://valuprop-api.onrender.com';

    const search = getSearch();
    if (!search.type) window.location.href = 'estimate.html';

    const typeLabels = {
      'Apartment': 'Apartment',
      'IndependentHouse': 'Independent House',
      'Villa': 'Villa',
      'LandPlot': 'Land / Plot'
    };
    const propLabel = (typeLabels[search.type] || search.type) +
      (search.bhk ? ' · ' + search.bhk : '') +
      ' · ' + (search.locality || search.address || '');

    document.getElementById('pay-prop').textContent = propLabel;
    document.getElementById('pay-email-confirm').textContent = search.email || 'your email address';

    async function initiatePayment() {
      const btn = document.getElementById('pay-btn');
      btn.disabled = true;
      btn.textContent = 'Opening payment…';

      const propId = sessionStorage.getItem('valuprop_prop_id');
      const valId = sessionStorage.getItem('valuprop_val_id');

      // DEMO mode (when key is placeholder)
      if (!RAZORPAY_KEY_ID || RAZORPAY_KEY_ID.indexOf('PASTE_YOUR') === 0) {
        btn.textContent = 'Processing demo…';
        let paidValId = null;
        if (valId) {
          try {
            const vr = await fetch(BACKEND_URL + '/api/payment/verify', {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify({
                razorpay_order_id: 'demo_order_' + Date.now(),
                razorpay_payment_id: 'demo_pay_' + Date.now(),
                razorpay_signature: 'demo_sig',
                valuation_id: parseInt(valId)
              })
            });
            const vd = await vr.json();
            paidValId = vd.paid_valuation_id;
          } catch(e) {}
        }
        setTimeout(function() {
          markPaid(search.phone || '', search.email || '');
          if (paidValId) sessionStorage.setItem('valuprop_paid_val_id', paidValId);
          window.location.href = 'detail.html';
        }, 1800);
        return;
      }

      // Create Razorpay order via backend
      let orderData;
      try {
        const r = await fetch(BACKEND_URL + '/api/payment/create-order', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({
            property_id: parseInt(propId || 0),
            valuation_id: parseInt(valId || 0)
          })
        });
        orderData = await r.json();
      } catch(e) {
        alert('Could not connect to payment server. Please try again.');
        btn.disabled = false;
        btn.textContent = 'Pay ₹99 & Get My Report →';
        return;
      }

      const options = {
        key: RAZORPAY_KEY_ID,
        amount: orderData.amount,
        currency: 'INR',
        name: 'valUProp.in',
        description: 'Detailed Report — ' + (search.locality || search.address || ''),
        order_id: orderData.order_id,
        prefill: {
          contact: search.phone || '',
          email: search.email || ''
        },
        notes: {
          propertyType: search.type,
          locality: search.locality || '',
          city: search.city || ''
        },
        theme: {color: '#1B3F6E'},
        handler: async function(response) {
          btn.textContent = 'Verifying payment…';
          try {
            const vr = await fetch(BACKEND_URL + '/api/payment/verify', {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify({
                razorpay_order_id: response.razorpay_order_id,
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_signature: response.razorpay_signature,
                valuation_id: parseInt(valId || 0)
              })
            });
            const vd = await vr.json();
            if (vd.verified) {
              markPaid(search.phone || '', search.email || '');
              sessionStorage.setItem('valuprop_payment_id', response.razorpay_payment_id);
              sessionStorage.setItem('valuprop_paid_val_id', vd.paid_valuation_id);
              window.location.href = 'detail.html';
            } else {
              alert('Payment verification failed. Please contact support@valuprop.in');
              btn.disabled = false;
              btn.textContent = 'Pay ₹99 & Get My Report →';
            }
          } catch(e) {
            markPaid(search.phone || '', search.email || '');
            window.location.href = 'detail.html';
          }
        },
        modal: {
          ondismiss: function() {
            btn.disabled = false;
            btn.textContent = 'Pay ₹99 & Get My Report →';
          }
        }
      };

      const rzp = new Razorpay(options);
      rzp.on('payment.failed', function(resp) {
        alert('Payment failed: ' + resp.error.description);
        btn.disabled = false;
        btn.textContent = 'Pay ₹99 & Get My Report →';
      });
      rzp.open();
    }
  </script>
</body>
</html>
